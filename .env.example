NODE_ENV=development
PORT=3000
SESSION_SECRET=your-long-random-string-here

# Google OAuth (optional, only needed if DEBUG_AUTH=false)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Debug auth - set to true for simple username login (no Google required)
DEBUG_AUTH=true

# Proxy trust - set to true when behind Caddy/AMP reverse proxy
TRUST_PROXY=true

# Client origin for CORS (your domain in production)
CLIENT_ORIGIN=http://localhost:3000
